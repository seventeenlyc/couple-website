{
    "_comment": "AI功能配置文件示例 - 复制为 ai_config.json 并填入你的配置",
    
    "enabled": false,
    "_enabled_comment": "是否启用AI功能。设置为true启用，false禁用",
    
    "api_provider": "openai",
    "_api_provider_comment": "API提供商: openai, deepseek, anthropic",
    
    "api_key": "YOUR_API_KEY_HERE",
    "_api_key_comment": "你的API密钥。OpenAI: sk-xxx, DeepSeek: sk-xxx",
    
    "api_endpoint": "",
    "_api_endpoint_comment": "自定义API端点（可选）。留空使用默认端点",
    
    "model": "gpt-3.5-turbo",
    "_model_comment": "使用的模型。OpenAI: gpt-3.5-turbo, gpt-4; DeepSeek: deepseek-chat",
    
    "max_tokens": 150,
    "_max_tokens_comment": "生成内容的最大令牌数",
    
    "temperature": 0.7,
    "_temperature_comment": "温度参数(0-1)。越高越随机，越低越确定",
    
    "timeout": 30,
    "_timeout_comment": "API调用超时时间（秒）",
    
    "retry_attempts": 3,
    "_retry_attempts_comment": "失败后重试次数",
    
    "retry_delay": 2,
    "_retry_delay_comment": "重试间隔（秒）",
    
    "rate_limit": {
        "enabled": true,
        "_enabled_comment": "是否启用速率限制",
        
        "max_calls_per_day": 100,
        "_max_calls_per_day_comment": "每天最大调用次数",
        
        "max_calls_per_hour": 20,
        "_max_calls_per_hour_comment": "每小时最大调用次数"
    },
    
    "cache": {
        "enabled": true,
        "_enabled_comment": "是否启用缓存",
        
        "ttl": 86400,
        "_ttl_comment": "默认缓存时间（秒），86400=24小时",
        
        "daily_quote_ttl": 86400,
        "_daily_quote_ttl_comment": "每日情话缓存时间（秒）",
        
        "anniversary_ttl": 3600,
        "_anniversary_ttl_comment": "纪念日提醒缓存时间（秒），3600=1小时"
    },
    
    "fallback": {
        "enabled": true,
        "_enabled_comment": "是否启用备用内容（当AI不可用时）",
        
        "quotes": [
